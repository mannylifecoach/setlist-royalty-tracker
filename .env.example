# =============================================================================
# Database (Neon Postgres via Vercel integration)
# =============================================================================

# Pooled connection — used at runtime by the app
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require&channel_binding=require

# Direct connection — used by inline migration scripts (drizzle/NNNN_*.sql)
# applied via `npx tsx -e "..."` with @neondatabase/serverless. See AGENTS.md.
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/database?sslmode=require

# =============================================================================
# Auth.js v5 (JWT session strategy)
# =============================================================================

# JWT signing + encryption secret. Also used to hash email-provider verification
# tokens (SHA-256(token + AUTH_SECRET)). Generate with: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Required by Auth.js v5 when running on a non-default port. Use the public
# origin in production; http://localhost:3000 in local dev.
AUTH_URL=http://localhost:3000

# =============================================================================
# Email (Resend) — magic links, 6-digit codes, expiration warnings, welcomes
# =============================================================================

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=notifications@yourdomain.com

# =============================================================================
# External APIs
# =============================================================================

# setlist.fm REST API key — register at https://www.setlist.fm/settings/api
SETLISTFM_API_KEY=your-setlistfm-api-key

# =============================================================================
# Internal secrets — compared via safeCompareSecret() (constant-time)
# =============================================================================

# Bearer token for Vercel cron endpoints (cron/scan, cron/expiration-check,
# cron/bmi-health-check). Generate any random string; rotate via Vercel UI.
CRON_SECRET=generate-a-random-secret

# Header value for admin endpoints (admin/stats). Generate any random string.
ADMIN_SECRET=generate-a-random-secret

# =============================================================================
# Optional — observability + dev convenience
# =============================================================================

# Override the email shown in the (app) nav (useful for demos / screenshots)
DEMO_EMAIL=

# PostHog product analytics. Public — bundled to client.
NEXT_PUBLIC_POSTHOG_KEY=

# Sentry error reporting. Public — bundled to client.
NEXT_PUBLIC_SENTRY_DSN=

# Used in email templates for absolute links back to the app. Defaults to
# https://setlistroyaltytracker.com when unset.
NEXT_PUBLIC_APP_URL=
