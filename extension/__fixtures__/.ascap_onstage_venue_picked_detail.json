{"modals":[{"tag":"ASIDE","id":"modal-login","cls":"c-modal","innerHTML":"\n    <div class=\"c-modal__wrap\">\n      <div class=\"c-modal__inner\">\n        <!-- modal body start -->\n        <div class=\"c-modal__body t-body_sm\">\n          <!-- modal wrap start -->\n          <div class=\"c-modal__body-group\">\n            <!-- modal header start -->\n            <div class=\"c-modal__header\" id=\"dialog-login-header-modal-login\">\n              <div class=\"c-modal__heading\">\n                <div><strong>Choose your account type:</strong></div>\n              </div>\n              <button class=\"c-modal__btn-close\" onclick=\"ga('send', 'event', 'MA-Loging-Modal', 'click link', 'close');\" aria-label=\"close modal\" data-modal-close=\"\">\n                <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" stroke-width=\"2\" viewBox=\"0 0 24 24\" class=\"c-icon c-icon--size-auto\">\n                  <title>Close Modal</title>\n                  <line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line>\n                  <line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line>\n                </svg>\n              </button>\n            </div>\n            <!-- modal header end -->\n            <!-- modal content start -->\n            <div class=\"c-modal__content\">\n              <dl>\n\n<dt class=\"s-bottom-sm\">\n                      <a href=\"/member-access#login\" class=\"h-color-b400 [ t-heading_xxl ]\" onclick=\"ga('send', 'event', 'MA-Loging-Modal', 'click link', 'Music Creator Login');\">\n                        Music Creator Login\n                        <svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" width=\"12\" height=\"12\" class=\"c-icon\" aria-hidden=\"true\"><polyline points=\"9 18 15 12 9 6\"></polyline></svg>\n                      </a>\n                  </dt>\n                  <dd>\n                    <p>Music Writers and Publishers.</p>\n                      <hr>\n                  </dd>\n<dt class=\"s-bottom-sm\">\n                      <button data-modal-id=\"sub-modal-login-licensing\" data-modal-close=\"\" aria-labelledby=\"sub-modal-login-licensing\" type=\"button\" class=\"c-btn c-btn--anchor h-color-b500\" onclick=\"ga('send', 'event', 'MA-Loging-Modal', 'click link', 'Licensee Login');\">\n                        <span class=\"t-heading_xxl\">\n                          Licensee <br>Login\n                          <svg xmlns=\"http://www.w3.org/2000/svg\" aria-hidden=\"true\" width=\"12\" height=\"12\" stroke-width=\"2\" viewBox=\"0 0 12 12\" class=\"c-icon\">\n                            <use xlink:href=\"#chevron-right\"></use>\n                          </svg>\n                        </span>\n                      </button>\n                  </dt>\n                  <dd>\n                    <p>Music Licensing customers including Restaurants, Bars, Colleges and Universities, Digital One Licensees and other customers should log in here.</p>\n                  </dd>\n              </dl>\n            </div>\n            <!-- modal content end -->\n          </div>\n          <!-- modal body group end -->\n        </div>\n        <!-- modal body end -->\n        <!-- modal clickable area start -->\n        <div class=\"c-modal__clickable-area\" data-modal-close=\"\"></div>\n        <!-- modal clickable area end -->\n      </div>\n    </div>\n  "},{"tag":"ASIDE","id":"modal-login-licensing","cls":"c-modal","innerHTML":"\n    <div class=\"c-modal__wrap\">\n      <div class=\"c-modal__inner\">\n        <!-- modal body start -->\n        <div class=\"c-modal__body t-body_sm\">\n          <!-- modal wrap start -->\n          <div class=\"c-modal__body-group\">\n            <!-- modal header start -->\n            <div class=\"c-modal__header\" id=\"dialog-login-header-modal-login-licensing\">\n              <div class=\"c-modal__heading\">\n                <div><strong>Choose your license type:</strong></div>\n              </div>\n              <button class=