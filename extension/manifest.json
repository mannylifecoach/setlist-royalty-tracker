{
  "manifest_version": 3,
  "name": "BMI Live Auto-Fill",
  "version": "1.1.0",
  "description": "Auto-fill BMI Live and ASCAP OnStage performance forms from Setlist Royalty Tracker data",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://ols.bmi.com/*",
    "https://www.ascap.com/*",
    "https://setlistroyalty.com/*",
    "https://setlist-royalty-tracker.vercel.app/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ols.bmi.com/*",
        "https://www.ascap.com/*",
        "https://setlistroyalty.com/*",
        "https://setlist-royalty-tracker.vercel.app/*"
      ],
      "js": ["content/pro-filler.js"],
      "css": ["content/pro-filler.css"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
